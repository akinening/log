---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import akinenMark from "../images/akinen.svg?raw";
import clickSoundUrl from "../sound/click-tap.mp3";
import hoverSoundUrl from "../sound/hover.mp3";

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = "/" } = Astro.props;
const canonical = new URL(path, Astro.site).href;
const currentPath = Astro.url.pathname;

// 指名検索時のリッチ表示用。ケーススタディ側の CreativeWork は [slug].astro が持つ
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Akinori Ozawa",
  jobTitle: "Senior Product Designer",
  url: new URL("/", Astro.site).href,
  worksFor: { "@type": "Organization", name: "株式会社ambr" },
  sameAs: [
    "https://www.linkedin.com/in/akinen",
    "https://note.com/012",
    "https://zenn.dev/012",
    "https://speakerdeck.com/akinen"
  ]
};

const navItems = [
  { label: "Top", href: "/", idx: "01" },
  { label: "Experience", href: "/experience/", idx: "02" },
  { label: "Perspectives", href: "/perspectives/", idx: "03" },
  { label: "Contact", href: "/contact/", idx: "04" }
];

const isCurrent = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Akinori Ozawa" />
    <!-- ページは検索対象のまま、画像だけ画像検索から除外する（robots.txt と二段構え） -->
    <meta name="robots" content="noimageindex" />
    <link rel="canonical" href={canonical} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personLd)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content="Akinori Ozawa" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={new URL("/og.png", Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400..700&family=Instrument+Serif:ital@0;1&family=Noto+Sans+JP:wght@400..700&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G1G5Q76XK4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      // View Transitions によるページ遷移は再読み込みを伴わないため、
      // 自動送信は無効化し astro:page-load で都度 page_view を送る
      gtag("config", "G-G1G5Q76XK4", { send_page_view: false });

      document.addEventListener("astro:page-load", () => {
        gtag("event", "page_view", {
          page_location: location.href,
          page_path: location.pathname,
          page_title: document.title
        });
      });
    </script>
  </head>
  <body>
    <div class="page-veil">
      <div class="page-veil-inner">
        <span class="page-veil-mark">
          <span class="page-veil-logo" set:html={akinenMark} />
        </span>
      </div>
    </div>

    <header class="mobile-bar">
      <a class="brand" href="/" aria-label="Akinori Ozawa — Top">
        <span class="brand-logo" set:html={akinenMark} />
      </a>
      <div class="mobile-bar-right">
        <nav class="mobile-nav" aria-label="Primary">
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="mobile-sound">
          <span class="mobile-sound-label en">Ambient</span>
          <button
            type="button"
            class="sound-switch"
            data-sound-switch
            data-haptic="toggle"
            aria-pressed="false"
            aria-label="アンビエントサウンドの再生切り替え"
          >
            <span class="sound-switch-dot" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </header>

    <div class="shell">
      <aside class="sidebar">
        <a class="brand" href="/" aria-label="Akinori Ozawa — Top">
          <span class="brand-logo" set:html={akinenMark} />
          <span class="brand-role">Senior Product Designer</span>
        </a>
        <nav class="side-nav" aria-label="Primary">
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
                <span class="idx">{item.idx}</span>
                {item.label}
              </a>
            ))
          }
        </nav>
        <p class="sidebar-foot">
          Tokyo, Japan<br />© 2026 Akinori Ozawa
        </p>
        <div class="sound-area">
          <div class="sound-toggle">
            <span class="overline">Ambient</span>
            <button
              type="button"
              class="sound-switch"
              data-sound-switch
              data-haptic="toggle"
              aria-pressed="false"
              aria-label="アンビエントサウンドの再生切り替え"
            >
              <span class="sound-switch-dot" aria-hidden="true"></span>
            </button>
          </div>
        </div>
      </aside>

      <main class="main">
        <div class="page">
          <slot />
        </div>
      </main>
    </div>

    <script is:inline>
      // View Transitions 経由のページ遷移ではイントロベールを再生しない
      // （スワップで <html> の属性ごと差し替わるためクラスではなく要素を除去する）
      document.addEventListener("astro:after-swap", () => {
        var veil = document.querySelector(".page-veil");
        if (veil) veil.remove();

        // Sound トグルの表示状態は描画前にここで同期する。
        // astro:page-load（描画後）まで待つと OFF → ON のtransitionが
        // 走ってドットが毎回スライドして見えてしまう
        var pressed = "false";
        try {
          if (sessionStorage.getItem("akinen-sound") === "on") pressed = "true";
        } catch (e) {}
        document.querySelectorAll("[data-sound-switch]").forEach(function (btn) {
          btn.setAttribute("aria-pressed", pressed);
        });
      });

      // ベールはコンテンツを妨げないよう、常に短い自動アニメーションで退場する。
      // サウンドはサイドバー／モバイルバーのトグルからのオプトイン
      (function () {
        var veil = document.querySelector(".page-veil");
        if (!veil) return;
        veil.classList.add("is-auto");
        veil.setAttribute("aria-hidden", "true");
        setTimeout(function () {
          if (veil.parentNode) veil.remove();
        }, 1600);
      })();
    </script>

    <script>
      import { enableAmbient, disableAmbient, saveChoice, readChoice } from "../scripts/ambient";

      // サイドバーの Sound トグル。ページ遷移のたびに要素が差し替わる
      // ため astro:page-load で毎回配線し直す。表示状態は選択済みの
      // 設定（sessionStorage）を単一の情報源として同期する
      document.addEventListener("astro:page-load", () => {
        const btns = document.querySelectorAll<HTMLButtonElement>("[data-sound-switch]");
        if (!btns.length) return;

        const sync = () => {
          const pressed = readChoice() === "on" ? "true" : "false";
          btns.forEach((btn) => btn.setAttribute("aria-pressed", pressed));
        };
        sync();

        btns.forEach((btn) => {
          btn.addEventListener("click", () => {
            const nowOn = btn.getAttribute("aria-pressed") !== "true";
            saveChoice(nowOn ? "on" : "off");
            if (nowOn) enableAmbient();
            else disableAmbient();
            sync();
          });
        });
      });
    </script>

    <script>
      const initReveal = () => {
        const targets = document.querySelectorAll<HTMLElement>(".rv:not(.is-inview)");
        if (!targets.length) return;

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          targets.forEach((el) => el.classList.add("is-inview"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-inview");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0, rootMargin: "0px 0px -8% 0px" }
        );

        targets.forEach((el) => observer.observe(el));
      };

      // 初回アクセス時のみ、イントロベールの開幕に合わせてリビールを遅らせる
      let firstLoad = true;
      document.addEventListener("astro:page-load", () => {
        const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const veil = document.querySelector(".page-veil");
        const delay = firstLoad && !reduced && veil ? 600 : 0;
        firstLoad = false;
        delay ? setTimeout(initReveal, delay) : initReveal();
      });
    </script>

    <script>
      import { initHaptics } from "../scripts/haptics";

      // タップ時のハプティックフィードバック（docs/haptic-guidelines.md）。
      // document への委譲のみなのでクリック音と同様ここで一度だけ登録する。
      initHaptics();
    </script>

    <script define:vars={{ clickSoundUrl, hoverSoundUrl }}>
      // クリック／ホバー時の効果音。View Transitions で document 自体は
      // 差し替わらないため、委譲リスナーはここで一度だけ登録すればよい。
      const CLICKABLE_SELECTOR =
        'a, button, summary, input[type="submit"], input[type="button"], input[type="reset"], [role="button"]';

      // Audio要素は毎回生成せず小さなプールを使い回す（GC・デコード負荷の削減）
      const makePool = (url, volume) => {
        const pool = Array.from({ length: 3 }, () => {
          const audio = new Audio(url);
          audio.preload = "auto";
          audio.volume = volume;
          return audio;
        });
        let i = 0;
        return () => {
          const audio = pool[i];
          i = (i + 1) % pool.length;
          audio.currentTime = 0;
          audio.play().catch(() => {});
        };
      };
      const playClick = makePool(clickSoundUrl, 0.1);
      const playHover = makePool(hoverSoundUrl, 0.2);

      document.addEventListener("click", (e) => {
        if (e.target instanceof Element && e.target.closest(CLICKABLE_SELECTOR)) {
          playClick();
        }
      });

      const hoverMedia = window.matchMedia("(hover: hover) and (pointer: fine)");
      let hoveredEl = null;

      document.addEventListener("pointerover", (e) => {
        if (!hoverMedia.matches || e.pointerType !== "mouse") return;
        const el = e.target instanceof Element ? e.target.closest(CLICKABLE_SELECTOR) : null;
        if (el?.closest(".work-card")) return;
        if (el && el !== hoveredEl) {
          hoveredEl = el;
          playHover();
        } else if (!el) {
          hoveredEl = null;
        }
      });
    </script>

    <script is:inline>
      // クリック位置に波紋を1つ広げる。document への委譲登録のみで
      // 済むため、他の恒久リスナーと同様ここで一度だけ登録すればよい
      const rippleReduced = window.matchMedia("(prefers-reduced-motion: reduce)");

      document.addEventListener("click", (e) => {
        if (rippleReduced.matches) return;
        const ripple = document.createElement("span");
        ripple.className = "click-ripple";
        ripple.style.left = e.clientX + "px";
        ripple.style.top = e.clientY + "px";
        ripple.addEventListener("animationend", () => ripple.remove());
        document.body.appendChild(ripple);
      });
    </script>
  </body>
</html>
