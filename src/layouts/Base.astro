---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import akinenMark from "../images/akinen.svg?raw";
import clickSoundUrl from "../sound/click-tap.mp3";
import hoverSoundUrl from "../sound/hover.mp3";

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = "/" } = Astro.props;
const canonical = new URL(path, Astro.site).href;
const currentPath = Astro.url.pathname;

const navItems = [
  { label: "Top", href: "/", idx: "01" },
  { label: "Experience", href: "/experience/", idx: "02" }
];

const isCurrent = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Akinori Ozawa" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content="Akinori Ozawa" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400..700&family=Instrument+Serif:ital@0;1&family=Noto+Sans+JP:wght@400..700&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />
  </head>
  <body>
    <div class="page-veil" aria-hidden="true">
      <span class="page-veil-mark">
        <span class="page-veil-logo" set:html={akinenMark} />
      </span>
    </div>

    <header class="mobile-bar">
      <a class="brand" href="/">
        <span class="brand-name en">Akinori Ozawa</span>
      </a>
      <nav class="mobile-nav" aria-label="Primary">
        {
          navItems.map((item) => (
            <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>

    <div class="shell">
      <aside class="sidebar">
        <a class="brand" href="/" aria-label="Akinori Ozawa — Top">
          <span class="brand-logo" set:html={akinenMark} />
          <span class="brand-role">Product Designer</span>
        </a>
        <nav class="side-nav" aria-label="Primary">
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
                <span class="idx">{item.idx}</span>
                {item.label}
              </a>
            ))
          }
        </nav>
        <p class="sidebar-foot">
          Tokyo, Japan<br />© 2026 Akinori Ozawa
        </p>
      </aside>

      <main class="main">
        <div class="page">
          <slot />
        </div>
      </main>
    </div>

    <script is:inline>
      // View Transitions 経由のページ遷移ではイントロベールを再生しない
      // （スワップで <html> の属性ごと差し替わるためクラスではなく要素を除去する）
      document.addEventListener("astro:after-swap", () => {
        var veil = document.querySelector(".page-veil");
        if (veil) veil.remove();
      });
    </script>

    <script>
      const initReveal = () => {
        const targets = document.querySelectorAll<HTMLElement>(".rv:not(.is-inview)");
        if (!targets.length) return;

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          targets.forEach((el) => el.classList.add("is-inview"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-inview");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );

        targets.forEach((el) => observer.observe(el));
      };

      // 初回アクセス時のみ、イントロベールの開幕に合わせてリビールを遅らせる
      let firstLoad = true;
      document.addEventListener("astro:page-load", () => {
        const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const delay = firstLoad && !reduced && document.querySelector(".page-veil") ? 600 : 0;
        firstLoad = false;
        delay ? setTimeout(initReveal, delay) : initReveal();
      });
    </script>

    <script define:vars={{ clickSoundUrl, hoverSoundUrl }}>
      // クリック／ホバー時の効果音。View Transitions で document 自体は
      // 差し替わらないため、委譲リスナーはここで一度だけ登録すればよい。
      const CLICKABLE_SELECTOR =
        'a, button, summary, input[type="submit"], input[type="button"], input[type="reset"], [role="button"]';

      const playSound = (url) => {
        const audio = new Audio(url);
        audio.volume = 0.5;
        audio.play().catch(() => {});
      };

      document.addEventListener("click", (e) => {
        if (e.target instanceof Element && e.target.closest(CLICKABLE_SELECTOR)) {
          playSound(clickSoundUrl);
        }
      });

      const hoverMedia = window.matchMedia("(hover: hover) and (pointer: fine)");
      let hoveredEl = null;

      document.addEventListener("pointerover", (e) => {
        if (!hoverMedia.matches || e.pointerType !== "mouse") return;
        const el = e.target instanceof Element ? e.target.closest(CLICKABLE_SELECTOR) : null;
        if (el && el !== hoveredEl) {
          hoveredEl = el;
          playSound(hoverSoundUrl);
        } else if (!el) {
          hoveredEl = null;
        }
      });
    </script>
  </body>
</html>
