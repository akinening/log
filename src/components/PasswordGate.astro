---
---

<div class="gate-wrap" data-gate-wrap>
  <div class="gate-content" data-gate-content aria-hidden="true">
    <slot />
  </div>
  <div class="gate" data-gate>
    <div class="gate-panel">
      <p class="overline">Enter Password</p>
      <p class="gate-message">この先を閲覧するにはあいことばが必要です</p>
      <form class="gate-form" data-gate-form novalidate>
        <input
          class="gate-input"
          type="password"
          name="password"
          placeholder="あいことば"
          aria-label="あいことば"
          autocomplete="off"
        />
      </form>
      <p class="gate-hint">Enter で送信</p>
      <p class="gate-error" data-gate-error aria-live="polite">あいことばが正しくありません</p>
    </div>
  </div>
</div>

<script>
  import { haptic } from "../scripts/haptics";

  const GATE_KEY = "akinen-gate-unlocked";
  const PASSWORD = "Saudade";

  const unlockAll = () => {
    document.querySelectorAll<HTMLElement>("[data-gate-wrap]").forEach((wrap) => {
      wrap.classList.add("is-unlocked");
      wrap.querySelector("[data-gate-content]")?.removeAttribute("aria-hidden");
    });
  };

  const initGate = () => {
    if (localStorage.getItem(GATE_KEY) === "1") {
      unlockAll();
    }

    const wraps = document.querySelectorAll<HTMLElement>("[data-gate-wrap]:not([data-gate-bound])");
    wraps.forEach((wrap) => {
      wrap.dataset.gateBound = "true";

      const form = wrap.querySelector<HTMLFormElement>("[data-gate-form]");
      const input = wrap.querySelector<HTMLInputElement>(".gate-input");
      const panel = wrap.querySelector<HTMLElement>(".gate-panel");
      const error = wrap.querySelector<HTMLElement>("[data-gate-error]");

      form?.addEventListener("submit", (e) => {
        e.preventDefault();
        if (input?.value === PASSWORD) {
          localStorage.setItem(GATE_KEY, "1");
          unlockAll();
          haptic("success");
          return;
        }

        error?.classList.add("is-visible");
        panel?.classList.remove("is-shake");
        requestAnimationFrame(() => panel?.classList.add("is-shake"));
        haptic("error");
        if (input) {
          input.value = "";
          input.focus();
        }
      });
    });
  };

  document.addEventListener("astro:page-load", initGate);
</script>
