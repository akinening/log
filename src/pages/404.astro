---
import Base from "../layouts/Base.astro";
---

<Base
  title="404 — Akinori Ozawa"
  description="お探しのページは見つかりませんでした。"
  path="/404"
>
  <section class="notfound">
    <p class="overline rv">Page Not Found</p>
    <h1 class="rv" style="--rv-delay:.08s">404</h1>
    <p class="rv" style="--rv-delay:.16s">お探しのページは移動したか、存在しません。</p>
    <a class="load-more rv" href="/" style="--rv-delay:.24s">
      <span>Back to Top</span>
      <span class="arrow" aria-hidden="true">←</span>
    </a>
  </section>
</Base>
