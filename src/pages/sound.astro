---
import Base from "../layouts/Base.astro";
---

<Base
  title="Sound — Akinori Ozawa"
  description="アンビエントサウンドを青いインクのにじみとして可視化するWebGLインタラクティブアート。音が透明な水面に落ち、にじみ、混ざり合い、余韻とともに透明へ還っていきます。"
  path="/sound/"
>
  <section
    class="sound-stage"
    data-sound-ink
    aria-label="アンビエントサウンドを青いインクとして可視化するインタラクティブアート"
  >
    <div class="sound-intro">
      <p class="overline rv">Interactive Sound Art</p>
      <h1 class="sound-title rv" style="--rv-delay:.08s">Sound</h1>
    </div>
    <div class="sound-hint is-hidden" data-sound-hint>
      <p class="sound-hint-note">
        いまは音のない、静かな水面だけが広がっています。<br />
        サウンドをONにすると、音がインクになって現れます。
      </p>
      <button type="button" class="sound-hint-btn en" data-sound-on>Sound On</button>
    </div>
  </section>
</Base>

<script>
  import { initSoundInk } from "../scripts/sound-ink";
  document.addEventListener("astro:page-load", initSoundInk);
</script>
