---
import Base from "../layouts/Base.astro";

// 経営とデザインをつなぐ思考メモの図解。主題は「デザインを成果物ではなく
// 事業インパクトで捉える」の一本で、01 因果の語り方（方法）→ 02 貢献の3方向（地図）
// → 03 ROIC分解（収益性の深掘り）と総論から各論へ進む。動的な切り替えは
// ROICツリー（03）のドリルダウンだけで、ほかのセクションは全情報を
// 静的HTMLとして常時表示する。

// 01: デザイン施策と経営成果を直接つなげず、
// 活動 → 行動の変化 → プロダクトKPI → 経営指標 の因果で語るための例
const chainStages = ["デザイン活動", "ユーザー・組織の変化", "プロダクトKPI", "経営指標"];

const causalChains = [
  {
    activity: "オンボーディング改善",
    behavior: "初期価値を早く実感する",
    kpi: "Activation率",
    outcome: "売上・CAC回収期間"
  },
  {
    activity: "UX改善",
    behavior: "継続利用が増える",
    kpi: "継続率・利用頻度",
    outcome: "LTV・収益の安定性"
  },
  {
    activity: "DesignOps",
    behavior: "再利用と標準化が進む",
    kpi: "開発リードタイム",
    outcome: "原価・Time to Market"
  },
  {
    activity: "UXリサーチ",
    behavior: "誤った仮説を早く捨てられる",
    kpi: "検証速度・成功率",
    outcome: "投資損失・事業リスク"
  },
  {
    activity: "コミュニティ設計",
    behavior: "ユーザー間の価値が増える",
    kpi: "UGC・紹介率",
    outcome: "獲得効率・Moat"
  }
];

// 02: デザインが事業価値へ貢献する3つの方向。ここは要点だけの地図に徹して、
// 収益性の分解は03へ委ねる（詳細の重複を持たない）
const valueDirections = [
  {
    number: "01",
    label: "Profitability",
    title: "収益性",
    tagline: "売上を伸ばし、コストを下げる",
    points: [
      "なめらかなUIと心地よいUXで、CVR・継続率・LTVを上げる",
      "DesignOpsとプロトタイピングで、手戻りと運用の負荷を減らす",
      "ブランディングで指名検索を増やし、価格競争から抜ける"
    ],
    metrics: ["CVR", "LTV", "継続率", "開発リードタイム"]
  },
  {
    number: "02",
    label: "Stability",
    title: "安定性",
    tagline: "収益と事業運営のリスクを下げる",
    points: [
      "ブランドへの愛着と、習慣・ワークフローへの組み込みで、解約する理由を減らす",
      "UXリサーチで投資の前に誤りを見つけ、PMFの確度を上げる",
      "例外や失敗まで想定した設計で、運用の破綻と信用毀損を防ぐ"
    ],
    metrics: ["NRR / GRR", "解約率", "問い合わせ・障害発生率"],
    note: "大切なのは囲い込みではなく、離れにくい便益を作ること"
  },
  {
    number: "03",
    label: "Moat",
    title: "Moat",
    tagline: "競合が追随しにくい循環を作る",
    points: [
      "コミュニティとUGCで、ユーザー間に価値が生まれる場を作る",
      "独自の世界観とブランド資産で、価格決定力を持つ",
      "一次情報と実践知で、何を作るべきかを見抜く精度を上げる"
    ],
    metrics: ["LTV / CAC", "紹介率・UGC", "価格決定力"]
  }
];

// 03: ROICを収益性×資本効率性に分解したドライバーツリー。
// リーフを選ぶと、デザインがその指標へ効く因果の説明と実例が表示される
// （ページ内で唯一の動的セクション）
const driverBranches = [
  {
    id: "profitability",
    label: "収益性",
    title: "NOPATマージン",
    formula: "NOPAT ÷ 売上高",
    leaves: [
      {
        id: "revenue",
        number: "A1",
        title: "売上とミックス",
        caption: "売上の質を上げる",
        body: "売上は、どれだけの人が価値を実感し、対価を払いつづけてくれるかで決まります。デザインは、最初の体験からつまずきを取り除いて定着を助け、価値が正しく伝わる導線と値づけへの納得感をつくることで、転換率と継続率——つまり売上の質に効きます。",
        example: {
          text: "goghでオンボーディングと課金フローを改善し、離脱率の低減に寄与",
          href: "/works/gogh-global/"
        }
      },
      {
        id: "variable",
        number: "A2",
        title: "変動費の生産性",
        caption: "粗利率を上げる",
        body: "売上に比例して増えるコストには、つくり直しや問い合わせ対応など、本来なくせたはずの仕事が多く含まれています。実装の前にプロトタイプで検証して手戻りを防ぎ、迷わないUIとわかりやすい文言で問い合わせ自体を減らすことで、デザインは粗利率の改善に貢献できます。",
        example: {
          text: "goghでVibe Codingによるプロトタイプ検証を定着させ、デザインFIXまでの手戻りを削減",
          href: "/works/gogh-global/"
        }
      },
      {
        id: "fixed",
        number: "A3",
        title: "固定費の生産性",
        caption: "同じ費用で成果を増やす",
        body: "人件費や設備といった固定費は、削ることよりも、同じ費用でどれだけ成果を出せるかを高めることが本質だと考えています。業務の観察にもとづいて道具と流れを設計しなおし、制作を型化・ドキュメント化して属人化を解くことで、デザインは一人あたりの生産性に効きます。",
        example: {
          text: "東京海上で属人化したポータルを再設計し、新人の立ち上がりを短縮",
          href: "/works/inhouse-design-culture/"
        }
      }
    ]
  },
  {
    id: "efficiency",
    label: "資本効率性",
    title: "投下資本回転率",
    formula: "売上高 ÷ 投下資本",
    leaves: [
      {
        id: "working-capital",
        number: "B1",
        title: "運転資本",
        caption: "お金がもどる速さを上げる",
        body: "事業は、仕入れてから売上が入金されるまでの、お金が寝ている時間が短いほど、少ない資本で回せます。購入フローの離脱をなくして売上を早く確定させ、予約販売や年払いのような先にお金が入る体験を設計することで、デザインは資金の回転を速めることに関われます。"
      },
      {
        id: "fixed-assets",
        number: "B2",
        title: "固定資産",
        caption: "持ちものの効率を上げる",
        body: "設備や拠点といった固定資産は、持つこと自体が資本を固定するリスクであり、稼働してはじめて価値になります。つくる前にプロトタイプで需要を確かめて過剰な投資を避け、対面や紙の手続きをオンラインの体験へ置きかえることで、デザインは持たずに済ませる選択を増やせます。"
      },
      {
        id: "portfolio",
        number: "B3",
        title: "事業ポートフォリオ",
        caption: "資本の行き先を選びなおす",
        body: "限られた資本をどの事業へ向けるかは、経営でもっとも大きな意思決定のひとつです。顧客体験の質を投資判断の材料として可視化し、新規事業はプロトタイプで安く検証して撤退の判断を早めることで、デザインは資本配分の精度を高めることに貢献できます。",
        example: {
          text: "損保グループで3つの新規事業PoCを、モックアップと現場検証で前進",
          href: "/works/tmnf-insurance-poc/"
        }
      }
    ]
  }
];

const driverLeaves = driverBranches.flatMap((branch) =>
  branch.leaves.map((leaf) => ({ ...leaf, branchLabel: branch.label }))
);
const defaultLeafId = driverBranches[0].leaves[0].id;
---

<Base
  title="Perspectives — Akinori Ozawa"
  description="デザインを「成果物」ではなく「事業インパクト」で捉えるための思考メモ。因果のつなぎ方、収益性・安定性・Moatの3方向、ROICへの分解を図解します。"
  path="/perspectives/"
>
  <header class="pv-head">
    <p class="overline rv">Current Thinking</p>
    <h1 class="pv-title rv" style="--rv-delay:.08s">Perspectives</h1>
    <p class="pv-lead rv" style="--rv-delay:.16s">
      いま考えていること、これから考えを深めたいテーマの記録です。
    </p>
  </header>

  <section class="pv-section rv" aria-labelledby="pv-chain-title">
    <div class="pv-section-head">
      <p class="overline">01 — Causal Chain</p>
      <h2 class="pv-h2" id="pv-chain-title">デザインの効果</h2>
    </div>

    <div class="pv-chain">
      <div class="pv-chain-header" aria-hidden="true">
        {chainStages.map((stage) => <span>{stage}</span>)}
      </div>
      <ol class="pv-chain-rows">
        {
          causalChains.map((chain) => (
            <li class="pv-chain-row">
              {[chain.activity, chain.behavior, chain.kpi, chain.outcome].map((value, step) => (
                <div class="pv-chain-cell">
                  <span>{chainStages[step]}</span>
                  <strong>{value}</strong>
                </div>
              ))}
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="pv-section rv" aria-labelledby="pv-dirs-title">
    <div class="pv-section-head">
      <p class="overline">02 — Three Directions</p>
      <h2 class="pv-h2" id="pv-dirs-title">事業価値への貢献</h2>
    </div>

    <div class="pv-dir-grid">
      {
        valueDirections.map((dir) => (
          <article class="pv-dir-card">
            <p class="pv-dir-eyebrow">
              <span class="serif-accent">{dir.number}</span>
              <span class="en">{dir.label}</span>
            </p>
            <h3>{dir.title}</h3>
            <p class="pv-dir-tagline">{dir.tagline}</p>
            <ul>{dir.points.map((point) => <li>{point}</li>)}</ul>
            {dir.note && <p class="pv-dir-note">{dir.note}</p>}
            <p class="pv-dir-metrics">
              <span>測る指標</span>
              {dir.metrics.map((metric) => <em>{metric}</em>)}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="pv-section rv" aria-labelledby="pv-tree-title" data-pv-tree>
    <div class="pv-section-head">
      <p class="overline">03 — ROIC Driver Tree</p>
      <h2 class="pv-h2" id="pv-tree-title">デザインとROIC</h2>
    </div>

    <div class="pv-tree" aria-label="ROICの改善ドライバーツリー">
      <div class="pv-tree-root-wrap">
        <div class="pv-tree-root">
          <span>最終指標</span>
          <strong class="en">ROIC</strong>
          <small>NOPAT ÷ 投下資本</small>
        </div>
      </div>

      <div class="pv-tree-branches">
        {
          driverBranches.map((branch, bIndex) => (
            <div
              class={`pv-tree-branch${bIndex === 0 ? " is-active" : ""}`}
              data-pv-branch={branch.id}
            >
              <div class="pv-branch-node">
                <span>{branch.label}</span>
                <strong>{branch.title}</strong>
                <small class="en">{branch.formula}</small>
              </div>
              <div class="pv-leaf-row">
                {branch.leaves.map((leaf) => (
                  <button
                    type="button"
                    class={`pv-leaf-node${leaf.id === defaultLeafId ? " is-active" : ""}`}
                    data-pv-leaf={leaf.id}
                    data-pv-branch-of={branch.id}
                    aria-pressed={leaf.id === defaultLeafId ? "true" : "false"}
                  >
                    <span class="serif-accent">{leaf.number}</span>
                    <strong>{leaf.title}</strong>
                    <small>{leaf.caption}</small>
                  </button>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="pv-action-panel" aria-live="polite">
      {
        driverLeaves.map((leaf) => (
          <div
            class={`pv-action-content${leaf.id === defaultLeafId ? " is-active" : ""}`}
            data-pv-action={leaf.id}
          >
            <div class="pv-action-head">
              <p class="pv-action-eyebrow">
                <span class="serif-accent">{leaf.number}</span>
                {leaf.branchLabel} — デザインはどう効くか
              </p>
              <h3>{leaf.title}</h3>
              <p class="pv-action-caption">{leaf.caption}</p>
              {leaf.example && (
                <a class="pv-action-example" href={leaf.example.href}>
                  <span class="pv-action-example-label">私の実例</span>
                  <span class="pv-action-example-text">
                    {leaf.example.text}
                    <span class="pv-action-example-arrow" aria-hidden="true">→</span>
                  </span>
                </a>
              )}
            </div>
            <p class="pv-action-body">{leaf.body}</p>
          </div>
        ))
      }
    </div>

    <p class="pv-tree-note">
      <span class="en">ROIC</span>
      ＝ NOPATマージン × 投下資本回転率
    </p>
  </section>
</Base>

<script>
  import { initPerspectives } from "../scripts/perspectives";
  import { initHeroFluid } from "../scripts/hero-fluid";

  document.addEventListener("astro:page-load", () => {
    initPerspectives();
    initHeroFluid(".pv-head");
  });
</script>
