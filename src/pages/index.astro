---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PasswordGate from "../components/PasswordGate.astro";
import HeroField from "../components/HeroField.astro";
import underline from "../images/underline.png";

const works = (await getCollection("works")).sort(
  (a, b) => a.data.order - b.data.order
);

const VISIBLE = 3;

const speaking = [
  {
    date: "2025.04",
    title: "CrossRel「AIとデザインのセカンドステージ」登壇",
    href: "https://aidesign2ndstage.peatix.com/"
  },
  {
    date: "2023.12",
    title: "Spectrum Tokyo Festival 2023「3D空間を扱うUI表現とユーザビリティ」",
    href: "https://spectrumfest2023.studio.site/en"
  },
  {
    date: "2023.06",
    title: "DIST.39「FigmaとBeziではじめるXR UIプロトタイピング」",
    href: "https://speakerdeck.com/akinen/figmatobezeldehazimeruxruipurototaipingu"
  },
  {
    date: "2022.07",
    title: "Figma Japan Community Event — Show & Tell 登壇",
    href: "https://www.facebook.com/ackiena/posts/pfbid0pM9b89XQcdWzgGNqkLrn8L2yoV4djjRLKfSL7knTofNxjEPwhEAY6HkekkNQqq1sl"
  },
  {
    date: "2020–22",
    title: "八王子IT勉強会「Yuruhachi.it」運営・登壇",
    href: null
  }
];

const writing = [
  {
    date: "2024.11",
    title: "200万DLを突破した作業集中プロダクト「gogh」のデザイン思想",
    href: "https://note.com/ambr/n/nbccabde15b46"
  },
  {
    date: "note",
    title: "デザインと事業のあいだ — 執筆アカウント",
    href: "https://note.com/012"
  },
  {
    date: "Zenn",
    title: "フロントエンドとデザインシステムの技術記事",
    href: "https://zenn.dev/012"
  },
  {
    date: "Deck",
    title: "登壇スライドアーカイブ（Speaker Deck）",
    href: "https://speakerdeck.com/akinen"
  }
];

const sns = [
  { label: "note", href: "https://note.com/012" },
  { label: "Zenn", href: "https://zenn.dev/012" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/akinen" },
  { label: "Speaker Deck", href: "https://speakerdeck.com/akinen" }
];
---

<Base
  title="Akinori Ozawa — Product Designer"
  description="複雑な事業・組織・プロダクト課題を構造化し、出荷し、事業成果につなげるシニアプロダクトデザイナー。グローバル300万DLのプロダクトグロース、デザイン組織構築、エンタープライズDXの実績。"
  path="/"
>
  <section class="hero">
    <HeroField />
    <p class="overline rv">Akinori Ozawa — Product Designer</p>
    <h1 class="hero-title rv" style="--rv-delay:.08s">
      Design that ships,<br />
      scales, and <span class="serif-accent"
        >pays back.<img
          class="hero-underline"
          src={underline.src}
          width={underline.width}
          height={underline.height}
          alt=""
          aria-hidden="true"
          loading="eager"
        /></span
      >
    </h1>
    <p class="hero-lead rv" style="--rv-delay:.16s">
      事業価値をデザインの力で最大化する。8年超のtoC/toB双方の知見と実装力を武器に、グロースと事業価値の向上にコミットします。
    </p>
  </section>

  <section class="section" id="work">
    <div class="section-head rv">
      <h2 class="section-title">Selected Work<sup>{String(works.length).padStart(2, "0")}</sup></h2>
    </div>

    <PasswordGate>
      <div class="work-grid" data-work-grid>
        {
          works.map((work, i) => (
            <a
              class:list={["work-card", "rv", { "is-hidden": i >= VISIBLE }]}
              href={`/works/${work.slug}/`}
              style={`--rv-delay:${(i % VISIBLE) * 0.08}s`}
            >
              <figure class="work-thumb">
                <img
                  src={work.data.thumbnail}
                  alt={work.data.title}
                  width="1600"
                  height="900"
                  loading={i < VISIBLE ? "eager" : "lazy"}
                  decoding="async"
                />
              </figure>
              <p class="work-meta">
                <span>{work.data.year}</span>
                <span class="dot" />
                <span>{work.data.tags[0]}</span>
              </p>
              <h3 class="work-title">{work.data.title}</h3>
              <p class="work-summary">{work.data.summary}</p>
            </a>
          ))
        }
      </div>

      <div class="load-more-wrap rv">
        <button class="load-more" type="button" data-load-more>
          <span>Load More</span>
          <span class="arrow" aria-hidden="true">↓</span>
        </button>
      </div>
    </PasswordGate>
  </section>

  <section class="section" id="sidework">
    <div class="section-head rv">
      <h2 class="section-title">Side Work</h2>
      <p class="section-note">登壇・執筆・コミュニティ</p>
    </div>
    <div class="sidework-block rv">
      <div class="sidework-head">
        <h3 class="sidework-heading">Speaking<sup>{String(speaking.length).padStart(2, "0")}</sup></h3>
        <p class="sidework-caption">登壇・トーク</p>
      </div>
      <ul class="sidework-list">
        {
          speaking.map((item) =>
            item.href ? (
              <li>
                <a class="sidework-item" href={item.href} target="_blank" rel="noopener">
                  <time>{item.date}</time>
                  <span class="t">{item.title}</span>
                  <span class="ext" aria-hidden="true">↗</span>
                </a>
              </li>
            ) : (
              <li>
                <span class="sidework-item">
                  <time>{item.date}</time>
                  <span class="t">{item.title}</span>
                </span>
              </li>
            )
          )
        }
      </ul>
    </div>
    <div class="sidework-block rv" style="--rv-delay:.08s">
      <div class="sidework-head">
        <h3 class="sidework-heading">Writing<sup>{String(writing.length).padStart(2, "0")}</sup></h3>
        <p class="sidework-caption">執筆・発信</p>
      </div>
      <ul class="sidework-list">
        {
          writing.map((item) => (
            <li>
              <a class="sidework-item" href={item.href} target="_blank" rel="noopener">
                <time>{item.date}</time>
                <span class="t">{item.title}</span>
                <span class="ext" aria-hidden="true">↗</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section" id="kind-words">
    <div class="section-head rv">
      <h2 class="section-title">Kind Words</h2>
      <p class="section-note">推薦文</p>
    </div>
    <PasswordGate>
      <div class="kind-quote-list">
        <blockquote class="kind-quote">
          <p class="kind-quote-text">
            たった1人で、goghモバイル版、Steam版のUIUX、goghウェブサイト、goghグッズストア、RobloxゲームのUI、プレスリリースや採用向けグラフィック全てを担当しています
          </p>
          <p class="kind-quote-emphasis serif-accent">めちゃくちゃすごい</p>
          <footer class="kind-quote-foot">
            <a
              class="kind-quote-source"
              href="https://x.com/tbutcoffee/status/2036052668951797931"
              target="_blank"
              rel="noopener"
            >
              <span>X（@tbutcoffee）の投稿</span>
              <span class="ext" aria-hidden="true">↗</span>
            </a>
          </footer>
        </blockquote>

        <blockquote class="kind-quote">
          <p class="kind-quote-text">
            LLMも使って事業仮説を高速に検証し、勝ち筋を作れるデザイナーです。
          </p>
          <footer class="kind-quote-foot">
            <span class="kind-quote-author">— S.T.さん</span>
          </footer>
        </blockquote>

        <blockquote class="kind-quote">
          <p class="kind-quote-text">
            抽象度の高い経営課題を、ユーザー体験とプロダクト戦略に落とし込み、チームを前進させる力があります。
          </p>
          <footer class="kind-quote-foot">
            <span class="kind-quote-author">— K.O.さん</span>
          </footer>
        </blockquote>
      </div>
    </PasswordGate>
  </section>

  <footer class="site-foot">
    <div class="foot-inner rv">
      <p class="foot-title">
        Let's design<br />what <span class="serif-accent">matters.</span>
      </p>
      <ul class="sns-links">
        {
          sns.map((item) => (
            <li>
              <a href={item.href} target="_blank" rel="noopener">
                {item.label}
                <span aria-hidden="true">↗</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <p class="foot-copy">© 2026 Akinori Ozawa — Tokyo, Japan</p>
  </footer>
</Base>

<script>
  import { initLoadMore } from "../scripts/load-more";
  import { initKindWords } from "../scripts/kind-words";
  import { initFluidPhotos } from "../scripts/fluid-photo";

  document.addEventListener("astro:page-load", () => {
    initLoadMore();
    initKindWords();
    initFluidPhotos(".work-thumb");
  });
</script>
