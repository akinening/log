---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const works = (await getCollection("works")).sort(
  (a, b) => a.data.order - b.data.order
);

const VISIBLE = 3;

const speaking = [
  {
    date: "2025.04",
    title: "CrossRel「AIとデザインのセカンドステージ」登壇",
    href: "https://aidesign2ndstage.peatix.com/"
  },
  {
    date: "2023.12",
    title: "Spectrum Tokyo Festival 2023「3D空間を扱うUI表現とユーザビリティ」",
    href: "https://spectrumfest2023.studio.site/en"
  },
  {
    date: "2023.06",
    title: "DIST.39「FigmaとBeziではじめるXR UIプロトタイピング」",
    href: "https://speakerdeck.com/akinen/figmatobezeldehazimeruxruipurototaipingu"
  },
  {
    date: "2022.07",
    title: "Figma Japan Community Event — Show & Tell 登壇",
    href: "https://www.facebook.com/ackiena/posts/pfbid0pM9b89XQcdWzgGNqkLrn8L2yoV4djjRLKfSL7knTofNxjEPwhEAY6HkekkNQqq1sl"
  },
  {
    date: "2020–22",
    title: "八王子IT勉強会「Yuruhachi.it」運営・登壇",
    href: null
  }
];

const writing = [
  {
    date: "2024.11",
    title: "200万DLを突破した作業集中プロダクト「gogh」のデザイン思想",
    href: "https://note.com/ambr/n/nbccabde15b46"
  },
  {
    date: "note",
    title: "デザインと事業のあいだ — 執筆アカウント",
    href: "https://note.com/012"
  },
  {
    date: "Zenn",
    title: "フロントエンドとデザインシステムの技術記事",
    href: "https://zenn.dev/012"
  },
  {
    date: "Deck",
    title: "登壇スライドアーカイブ（Speaker Deck）",
    href: "https://speakerdeck.com/akinen"
  }
];

const sns = [
  { label: "note", href: "https://note.com/012" },
  { label: "Zenn", href: "https://zenn.dev/012" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/akinen" },
  { label: "Speaker Deck", href: "https://speakerdeck.com/akinen" }
];
---

<Base
  title="Akinori Ozawa — Senior Product Designer"
  description="複雑な事業・組織・プロダクト課題を構造化し、出荷し、事業成果につなげるシニアプロダクトデザイナー。グローバル250万DLのプロダクトグロース、デザイン組織構築、エンタープライズDXの実績。"
  path="/"
>
  <section class="hero">
    <p class="overline rv">Akinori Ozawa — Senior Product Designer</p>
    <h1 class="hero-title rv" style="--rv-delay:.08s">
      Design that ships,<br />
      scales, and <span class="serif-accent">pays back.</span>
    </h1>
    <p class="hero-lead rv" style="--rv-delay:.16s">
      複雑な事業・組織・プロダクトの課題を構造化し、出荷し、数字で証明する。
      UX/UIデザインとエンジニアリング8年超の専門性を基盤に、0→1の価値検証からグローバルグロース、
      デザイン組織の構築までを一貫して率いるプロダクトデザイナーです。
    </p>
    <div class="hero-facts rv" style="--rv-delay:.24s">
      <p class="fact en"><strong>250万+</strong><span>グローバルDL</span></p>
      <p class="fact en"><strong>8年+</strong><span>デザイン × エンジニアリング</span></p>
      <p class="fact en"><strong>3→14名</strong><span>デザイン組織構築</span></p>
    </div>
  </section>

  <section class="section" id="work">
    <div class="section-head rv">
      <h2 class="section-title">Selected Work<sup>{String(works.length).padStart(2, "0")}</sup></h2>
      <p class="section-note">課題の構造化 → 出荷 → 事業インパクト</p>
    </div>

    <div class="work-grid" data-work-grid>
      {
        works.map((work, i) => (
          <a
            class:list={["work-card", "rv", { "is-hidden": i >= VISIBLE }]}
            href={`/works/${work.slug}/`}
            style={`--rv-delay:${(i % VISIBLE) * 0.08}s`}
          >
            <figure class="work-thumb">
              <img
                src={work.data.thumbnail}
                alt={work.data.title}
                width="1600"
                height="900"
                loading={i < VISIBLE ? "eager" : "lazy"}
              />
            </figure>
            <p class="work-meta">
              <span>{work.data.year}</span>
              <span class="dot" />
              <span>{work.data.tags[0]}</span>
            </p>
            <h3 class="work-title">{work.data.title}</h3>
            <p class="work-summary">{work.data.summary}</p>
          </a>
        ))
      }
    </div>

    <div class="load-more-wrap rv">
      <button class="load-more" type="button" data-load-more>
        <span>Load More</span>
        <span class="arrow" aria-hidden="true">↓</span>
      </button>
    </div>
  </section>

  <section class="section" id="sidework">
    <div class="section-head rv">
      <h2 class="section-title">Side Work</h2>
      <p class="section-note">登壇・執筆・コミュニティ</p>
    </div>
    <div class="sidework-grid">
      <div class="sidework-col rv">
        <h3>Speaking</h3>
        <ul class="sidework-list">
          {
            speaking.map((item) =>
              item.href ? (
                <li>
                  <a class="sidework-item" href={item.href} target="_blank" rel="noopener">
                    <time>{item.date}</time>
                    <span class="t">{item.title}</span>
                    <span class="ext" aria-hidden="true">↗</span>
                  </a>
                </li>
              ) : (
                <li>
                  <span class="sidework-item">
                    <time>{item.date}</time>
                    <span class="t">{item.title}</span>
                  </span>
                </li>
              )
            )
          }
        </ul>
      </div>
      <div class="sidework-col rv" style="--rv-delay:.1s">
        <h3>Writing</h3>
        <ul class="sidework-list">
          {
            writing.map((item) => (
              <li>
                <a class="sidework-item" href={item.href} target="_blank" rel="noopener">
                  <time>{item.date}</time>
                  <span class="t">{item.title}</span>
                  <span class="ext" aria-hidden="true">↗</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <footer class="site-foot">
    <div class="foot-inner rv">
      <p class="foot-title">
        Let's design<br />what <span class="serif-accent">matters.</span>
      </p>
      <ul class="sns-links">
        {
          sns.map((item) => (
            <li>
              <a href={item.href} target="_blank" rel="noopener">
                {item.label}
                <span aria-hidden="true">↗</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <p class="foot-copy">© 2026 Akinori Ozawa — Tokyo, Japan</p>
  </footer>
</Base>

<script>
  const initLoadMore = () => {
    const button = document.querySelector<HTMLButtonElement>("[data-load-more]");
    const grid = document.querySelector("[data-work-grid]");
    if (!button || !grid || button.dataset.bound) return;
    button.dataset.bound = "true";

    button.addEventListener("click", () => {
      const hidden = grid.querySelectorAll<HTMLElement>(".work-card.is-hidden");
      hidden.forEach((card, i) => {
        card.classList.remove("is-hidden");
        card.classList.remove("is-inview");
        card.style.setProperty("--rv-delay", `${i * 0.1}s`);
        requestAnimationFrame(() => {
          requestAnimationFrame(() => card.classList.add("is-inview"));
        });
      });
      button.classList.add("is-done");
    });
  };

  document.addEventListener("astro:page-load", initLoadMore);
</script>
